// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Extension: ESBuild+Watch",
            "type": "shell",
            "command": "pnpm",
            "args": [
                "--filter",
                "vscode-containers",
                "run",
                "build:esbuild",
                "--",
                "--watch"
            ],
            "problemMatcher": "$esbuild-watch",
            "presentation": {
                "reveal": "silent",
            },
            "group": {
                "kind": "build",
            },
            "isBackground": true,
        },
        {
            "label": "Extension: Check+Watch",
            "type": "shell",
            "command": "pnpm",
            "args": [
                "--filter",
                "vscode-containers",
                "run",
                "build:check",
                "--",
                "--watch"
            ],
            "problemMatcher": {
                "base": "$tsc-watch",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/extensions/vscode-containers"
                ]
            },
            "presentation": {
                "revealProblems": "onProblem",
            },
            "group": {
                "kind": "build",
                "isDefault": true,
            },
            "isBackground": true,
        },
    ],
}
