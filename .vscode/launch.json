// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode-containers",
            ],
            "env": {
                "DEBUGTELEMETRY": "1",
            },
            "outFiles": [
                "${workspaceFolder}/extensions/vscode-containers/dist/**/*.{js,mjs,cjs}",
            ],
            "preLaunchTask": "Extension: ESBuild+Watch",
        },
        {
            "name": "Run Tests",
            "type": "extensionHost",
            "request": "launch",
            "testConfiguration": "${workspaceFolder}/extensions/vscode-containers/.vscode-test.mjs",
            "env": {
                "DEBUGTELEMETRY": "1",
                "TSX_TSCONFIG_PATH": "${workspaceFolder}/extensions/vscode-containers/tsconfig.json", // Necessary only for F5 to get tsx to allow decorators
            },
            "outFiles": [
                "${workspaceFolder}/extensions/vscode-containers/dist/**/*.{js,mjs,cjs}",
                "${workspaceFolder}/extensions/vscode-containers/src/test/**/*.{ts,mts,cts}", // We are using TSX so out files *are* the source files
            ],
            "preLaunchTask": "Extension: ESBuild+Watch",
        },
        {
            "name": "Container client integration tests",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/packages/vscode-container-client",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "run",
                "testintegration"
            ],
            "env": {
                "CONTAINER_CLIENT_TYPE": "${input:containerRuntime}", // Set to 'docker', 'podman', or 'nerdctl'
                "RUN_IN_WSL": "0", // Set to 1 if running in WSL
                "DOCKER_HUB_USERNAME": "${input:dockerHubUsername}",
                "DOCKER_HUB_PAT": "${input:dockerHubPAT}"
            },
            "skipFiles": [
                "<node_internals>/**"
            ],
            "preLaunchTask": "Build: vscode-processutils",
        },
    ],
    "inputs": [
        {
            "id": "containerRuntime",
            "type": "pickString",
            "description": "Select the container runtime to use for integration tests",
            "options": [
                "docker",
                "podman",
                "nerdctl"
            ],
            "default": "docker"
        },
        {
            "id": "dockerHubUsername",
            "type": "promptString",
            "description": "Enter your Docker Hub username (or leave blank to skip the login test)",
            "default": ""
        },
        {
            "id": "dockerHubPAT",
            "type": "promptString",
            "description": "Enter your Docker Hub Personal Access Token (or leave blank to skip the login test)",
            "default": "",
            "password": true
        }
    ]
}
