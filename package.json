{
    "name": "@microsoft/vscode-containers-monorepo",
    "version": "0.0.0",
    "private": true,
    "description": "Container Tools for Visual Studio Code",
    "homepage": "https://github.com/microsoft/vscode-containers#readme",
    "bugs": {
        "url": "https://github.com/microsoft/vscode-containers/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/microsoft/vscode-containers.git"
    },
    "license": "MIT",
    "author": "Microsoft Corporation",
    "scripts": {
        "postinstall": "node ./scripts/postinstall.mjs",
        "lint": "pnpm -r --parallel run lint",
        "build": "pnpm -r run build",
        "package": "pnpm -r --parallel run package",
        "test": "pnpm -r run test",
        "clean": "pnpm -r --parallel run clean",
        "all": "pnpm clean && pnpm lint && pnpm build && pnpm package && pnpm test"
    },
    "packageManager": "pnpm@11.8.0",
    "engines": {
        "vscode": "^1.105.0"
    },
    "devDependencies": {
        "@microsoft/vscode-azext-eng": "^1.1.0-alpha.3",
        "@types/node": "22.x",
        "@types/vscode": "1.105.0",
        "@typescript/native": "npm:typescript@7.0.2",
        "@vscode/vsce": "^3.9.2"
    }
}
