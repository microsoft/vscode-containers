{
    "name": "@microsoft/vscode-processutils",
    "author": "Microsoft Corporation",
    "version": "0.2.2",
    "description": "Library support for building command lines and running external processes, primarily for use in VS Code.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/microsoft/vscode-containers",
        "directory": "packages/vscode-processutils"
    },
    "bugs": {
        "url": "https://github.com/microsoft/vscode-containers/issues"
    },
    "homepage": "https://github.com/microsoft/vscode-containers/blob/main/packages/vscode-processutils/README.md",
    "publishConfig": {
        "access": "public"
    },
    "module": "dist/esm/index.js",
    "main": "dist/cjs/index.js",
    "types": "dist/esm/index.d.ts",
    "scripts": {
        "build": "pnpm run build:esm && pnpm run build:cjs",
        "build:esm": "tsc",
        "build:cjs": "tsc --outDir dist/cjs --module nodenext --moduleResolution nodenext --declaration false",
        "lint": "eslint --max-warnings 0",
        "package": "pnpm pack",
        "test": "mocha",
        "testintegration": "mocha --grep \"(integration)\"",
        "clean": "node ../../scripts/clean.mjs"
    },
    "dependencies": {
        "tree-kill": "^1.2.2",
        "which": "^5.0.0"
    },
    "devDependencies": {
        "@types/which": "^3.0.4",
        "vscode-jsonrpc": "^8.0.1"
    },
    "mocha": {
        "node-option": [
            "experimental-transform-types",
            "import=@microsoft/vscode-azext-eng/mocha"
        ],
        "spec": [
            "src/test/**/*.test.ts"
        ],
        "grep": [
            "(unit)"
        ]
    }
}
