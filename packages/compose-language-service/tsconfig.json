{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist/esm",
        "rootDir": "src",
        "inlineSources": false,
        // `types` arrays do not merge across `extends`; repeat `node` (from the base)
        // alongside the extra ambient types this package needs (mocha for its tests,
        // vscode for the client-side features under src/vscode).
        "types": [
            "node",
            "mocha",
            "vscode",
        ],
    },
    "exclude": [
        "src/test/clientExtension",
        "**/dist",
        "bin"
    ],
}
