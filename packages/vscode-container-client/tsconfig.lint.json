{
    // This tsconfig lets the linter/type-checker resolve the sibling
    // vscode-processutils package from source without requiring it to be built first.
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "paths": {
            "@microsoft/vscode-processutils": [
                "../vscode-processutils/src/index.ts"
            ]
        }
    },
    // Unlike the build config, the linter should still type-check the test files.
    "exclude": [
        "**/node_modules",
        "**/dist",
        "**/.vscode-test"
    ],
}
