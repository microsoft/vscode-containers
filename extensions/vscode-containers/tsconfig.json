{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "out",
        "rootDir": "../..",
        "declaration": false, // The extension is bundled by esbuild and never emits declarations
        "noUnusedLocals": false, // ESLint takes care of this for us
        "noUnusedParameters": false, // ESLint takes care of this for us
        "noImplicitAny": false, // TODO ~14 errors
        "noImplicitOverride": false, // TODO ~78 errors
        "strictNullChecks": false, // TODO ~425 errors
        "paths": {
            // Resolve the workspace-local packages and the compose-language-service subpath
            // imports from source so the type checker and linter match esbuild (which bundles
            // the same source).
            "@microsoft/vscode-container-client": [
                "../../packages/vscode-container-client/src/index.ts"
            ],
            "@microsoft/vscode-docker-registries": [
                "../../packages/vscode-docker-registries/src/index.ts"
            ],
            "@microsoft/vscode-processutils": [
                "../../packages/vscode-processutils/src/index.ts"
            ],
            "@microsoft/compose-language-service/client": [
                "../../packages/compose-language-service/src/client/index.ts"
            ],
            "@microsoft/compose-language-service/vscode": [
                "../../packages/compose-language-service/src/vscode/index.ts"
            ],
        },
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
